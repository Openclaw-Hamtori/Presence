{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "jsx": "react-native",
    "types": ["react-native"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "android", "ios"]
}
